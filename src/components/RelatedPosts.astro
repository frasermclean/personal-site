---
import { Carousel, CarouselContent, CarouselItem } from '@/components/starwind/carousel';
import { POSTS_PATH } from '@/constants';
import type { CollectionEntry } from 'astro:content';
import PostCardLink from './PostCardLink.astro';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="my-8">
      <h2 id="related-posts" class="mb-4 font-heading text-2xl font-bold text-primary md:text-4xl">
        Related Posts
      </h2>
      <Carousel class="mx-auto w-full max-w-6xl">
        <CarouselContent>
          {posts.map((post) => (
            <CarouselItem class="md:basis-1/2 lg:basis-1/3">
              <PostCardLink href={`${POSTS_PATH}/${post.id}`} {...post.data} />
            </CarouselItem>
          ))}
        </CarouselContent>
      </Carousel>
    </section>
  )
}
