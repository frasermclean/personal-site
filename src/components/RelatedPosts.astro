---
import { Carousel, CarouselContent, CarouselItem } from '@/components/starwind/carousel';
import { POSTS_PATH } from '@/constants';
import { getCollection } from 'astro:content';
import PostCardLink from './PostCardLink.astro';

interface Props {
  slug: string;
  category?: string;
  tags: string[];
  maxResults?: number;
}

const { slug, category, tags, maxResults = 3 } = Astro.props;

// fetch all posts except the current one
const otherPosts = (await getCollection('posts')).filter((post) => post.id !== slug);

// calculate relevance score for each post
const scoredPosts = otherPosts.map((post) => {
  let score = 0;

  // same category adds points
  if (category && post.data.category === category) {
    score += 5;
  }

  // each shared tag adds points
  const sharedTags = post.data.tags.filter((tag) => tags.includes(tag));
  score += sharedTags.length * 2;

  return { post, score };
});

// sort by score (descending) and take the top results
const relatedPosts = scoredPosts
  .filter((item) => item.score > 0) // Only include posts with some relevance
  .sort((a, b) => b.score - a.score)
  .slice(0, maxResults)
  .map((item) => item.post);
---

{
  relatedPosts.length > 0 && (
    <section class="my-8">
      <h2 id="related-posts" class="mb-4 font-heading text-2xl font-bold text-primary md:text-4xl">
        Related Posts
      </h2>
      <Carousel class="mx-auto w-full max-w-6xl">
        <CarouselContent>
          {relatedPosts.map((post) => (
            <CarouselItem class="md:basis-1/2 lg:basis-1/3">
              <PostCardLink href={`${POSTS_PATH}/${post.id}`} {...post.data} />
            </CarouselItem>
          ))}
        </CarouselContent>
      </Carousel>
    </section>
  )
}
