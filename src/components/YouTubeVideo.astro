---
interface Props {
  videoId: string;
  title: string;
  aspectRatio?: '16:9' | '21:9' | '4:3' | '1:1';
  loading?: 'lazy' | 'eager';
}
const { videoId, title = 'YouTube Video', aspectRatio = '16:9', loading = 'lazy' } = Astro.props;
const aspectRatios: Record<string, string> = {
  '16:9': '56.25%',
  '21:9': '42.86%',
  '4:3': '75%',
  '1:1': '100%'
};
---

<div class="relative w-full overflow-hidden" style={`padding-top: ${aspectRatios[aspectRatio]}`}>
  <iframe
    class="absolute top-0 left-0 h-full w-full"
    src={`https://www.youtube.com/embed/${videoId}`}
    title={title}
    loading={loading}
    allow="fullscreen"
  >
  </iframe>
</div>
