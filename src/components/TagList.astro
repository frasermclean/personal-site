---
import { TAGS_PATH } from '@/constants';
import TagIcon from '@tabler/icons/outline/tag.svg';
import RoundedLink from './RoundedLink.astro';

interface Props {
  title?: string;
  tags: string[];
}

const { title = 'Tags', tags } = Astro.props;
---

<section>
  <div class="mb-2 flex items-center gap-2 text-secondary">
    <TagIcon width={20} height={20} />
    <h2 class="font-heading text-xl font-bold">{title}</h2>
  </div>

  <nav>
    <ul class="flex flex-wrap items-center gap-2">
      {
        tags.map((tag) => (
          <li>
            <RoundedLink href={`${TAGS_PATH}/${tag}`}>{tag}</RoundedLink>
          </li>
        ))
      }
    </ul>
  </nav>
</section>
