---
import Link from '@/components/links/Link.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/starwind/card';

interface Props {
  title: string;
  description: string;
  url: string;
}

const { title, description, url } = Astro.props;
---

<Link href={url}>
  <Card class="gap-4 transition-colors hover:bg-accent/80">
    <CardHeader>
      <CardTitle>{title}</CardTitle>
    </CardHeader>
    <CardContent class="text-muted-foreground">
      {description}
    </CardContent>
  </Card>
</Link>
