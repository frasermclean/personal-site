---
import { Card, CardDescription, CardHeader, CardTitle } from '@/components/starwind/card';

interface Props {
  title: string;
  description: string;
  url: string;
}

const { title, description, url } = Astro.props;
---

<Card as="a" href={url} target="_blank" rel="noopener noreferrer" class="hover:bg-accent/80">
  <CardHeader>
    <CardTitle>{title}</CardTitle>
    <CardDescription>{description}</CardDescription>
  </CardHeader>
</Card>
