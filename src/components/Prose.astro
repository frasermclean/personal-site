---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<article
  class:list={[
    className,
    'prose prose-neutral md:prose-lg lg:prose-xl dark:prose-invert', // base
    'prose-headings:font-heading prose-h2:text-primary prose-h3:text-secondary prose-h4:text-secondary/90', // headings
    'prose-a:text-accent prose-a:no-underline prose-a:hover:underline' // links
  ]}
>
  <slot />
</article>
