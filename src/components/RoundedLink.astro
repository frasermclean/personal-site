---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;
const { href, class: className, ...rest } = Astro.props as Props;
---

<a
  href={href}
  class="inline-block rounded-full bg-accent/10 px-3 py-1 text-sm font-medium text-accent hover:bg-accent/20"
  {...rest}
>
  <slot />
</a>
