---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'time'> & { date: Date };

const { date, ...rest } = Astro.props as Props;
---

<time datetime={date.toISOString()} {...rest}>
  {
    date.toLocaleDateString('en-AU', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  }
</time>
