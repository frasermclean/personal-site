---
import { Button } from '@/components/starwind/button';
import { Card } from '@/components/starwind/card';
import SourceCodeIcon from '@tabler/icons/outline/source-code.svg';
import WwwIcon from '@tabler/icons/outline/world-www.svg';
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';
import { getEntry } from 'astro:content';

interface Props {
  id: string;
  image?: ImageMetadata;
}

const { id, image } = Astro.props;

const project = await getEntry('projects', id);
if (!project) {
  throw new Error(`Project with ID "${Astro.props.id}" not found.`);
}

const { name, description, links, features, technologies } = project.data;
const imageAlt = `Screenshot of ${name} project`;
const linksArray = [
  { href: links.website, label: 'Website', Icon: WwwIcon },
  { href: links.source, label: 'Source Code', Icon: SourceCodeIcon }
];
---

<Card as="li" class="grid grid-cols-1 gap-4 p-4 md:grid-cols-3 md:p-6">
  {
    image && (
      <Picture
        src={image}
        alt={imageAlt}
        width={320}
        formats={['avif', 'webp']}
        class="mb-4 w-full rounded-md object-cover shadow-lg md:col-start-3 md:row-start-1"
      />
    )
  }

  <section class="flex flex-col gap-4 md:col-span-2 md:col-start-1 md:row-start-1">
    <h2 class="font-heading text-xl leading-none font-semibold tracking-tight">{name}</h2>
    <section>
      <div class="flex flex-col gap-2">
        {description.map((line) => <p class="text-muted-foreground">{line}</p>)}
      </div>
    </section>

    {
      features.length > 0 && (
        <section>
          <h3 class="mb-2 font-heading text-lg font-semibold">Notable Features</h3>
          <ul class="list-outside list-disc space-y-1 pl-6">
            {features.map((feature) => (
              <li class="text-muted-foreground">{feature}</li>
            ))}
          </ul>
        </section>
      )
    }

    <section>
      <h3 class="mb-2 font-heading text-lg font-semibold">Technologies</h3>
      <ul class="flex flex-wrap gap-2">
        {
          technologies.map((tech) => (
            <li class="rounded-full bg-neutral-300 px-3 py-1 text-sm dark:bg-neutral-700">{tech}</li>
          ))
        }
      </ul>
    </section>

    <nav class="mt-3 flex flex-wrap gap-2">
      {
        linksArray.map(({ label, href, Icon }) => (
          <Button variant={label === 'Website' ? 'primary' : 'default'} {href} target="_blank" rel="noopener nofollow">
            <Icon class="mr-1" width={16} height={16} />
            {label}
          </Button>
        ))
      }
    </nav>
  </section>
</Card>
