---
import { Button } from '@/components/starwind/button';
import { Card } from '@/components/starwind/card';
import GithubIcon from '@tabler/icons/outline/brand-github.svg';
import WorldWwwIcon from '@tabler/icons/outline/world-www.svg';
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';
import { getEntry } from 'astro:content';

interface Props {
  id: string;
  image?: ImageMetadata;
}

const { id, image } = Astro.props;

const project = await getEntry('projects', id);
if (!project) {
  throw new Error(`Project with ID "${Astro.props.id}" not found.`);
}

const { name, description, projectUrl, repositoryUrl, technologies } = project.data;
const imageAlt = `Screenshot of ${name} project`;
---

<Card as="li" class="grid grid-cols-1 gap-4 p-4 md:grid-cols-3 md:p-6">
  {
    image && (
      <Picture
        src={image}
        alt={imageAlt}
        width={320}
        formats={['avif', 'webp']}
        class="mb-4 w-full rounded-md object-cover md:col-start-3 md:row-start-1"
      />
    )
  }

  <section class="flex flex-col gap-4 md:col-span-2 md:col-start-1 md:row-start-1">
    <section>
      <h3 class="mb-4 font-heading text-xl leading-none font-semibold tracking-tight">{name}</h3>
      <p class="text-muted-foreground">{description}</p>
    </section>

    <section>
      <h3 class="mb-2 text-lg font-semibold">Technologies</h3>
      <ul class="mb-4 flex flex-wrap gap-2">
        {
          technologies.map((tech) => (
            <li class="rounded-full bg-neutral-300 px-3 py-1 text-sm dark:bg-neutral-700">{tech}</li>
          ))
        }
      </ul>
    </section>

    <nav class="flex gap-2">
      {
        projectUrl && (
          <Button variant="primary" href={projectUrl}>
            <WorldWwwIcon class="mr-1 inline-block h-4 w-4" />
            Website
          </Button>
        )
      }
      <Button href={repositoryUrl}><GithubIcon class="mr-1 inline-block h-4 w-4" />Source Code</Button>
    </nav>
  </section>
</Card>
