---
import { Button } from '@/components/starwind/button';
import { isOwner } from '@/lib/auth/owner-check';
import { getLinks } from '@/lib/syndication';
import EditIcon from '@tabler/icons/outline/edit.svg';
import ShareIcon from '@tabler/icons/outline/share-3.svg';
import { getEntry } from 'astro:content';
import SyndicationLink from './SyndicationLink.astro';

interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;

const entry = await getEntry('posts', slug);
if (!entry) {
  throw new Error(`Post with slug "${slug}" not found.`);
}

// read links from frontmatter and stored overrides, then merge them with overrides taking precedence
const { syndication: frontmatterLinks } = entry.data;
const overriddenLinks = await getLinks(slug);
const effectiveLinks = overriddenLinks !== null ? overriddenLinks : frontmatterLinks;

const canEdit = isOwner(Astro.locals.user);
---

{
  effectiveLinks.length > 0 && (
    <section class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-secondary">
        <ShareIcon width={20} height={20} />
        <h2 class="font-heading text-xl font-bold">Syndication</h2>
      </div>
      <ul class="ml-3" data-syndication-list>
        {effectiveLinks.map((href) => (
          <li>
            <SyndicationLink {href} />
          </li>
        ))}
      </ul>

      {canEdit && (
        <Button size="sm" variant="outline" class="w-40">
          <EditIcon width={16} height={16} class="mr-1" />
          Edit Links
        </Button>
      )}
    </section>
  )
}
