---
import Link from '@/components/links/Link.astro';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/starwind/avatar';
import { Tooltip, TooltipContent, TooltipTrigger } from '@/components/starwind/tooltip';
import type { Like } from '@/lib/reaction-types';

interface Props extends Like {}

const { authorName, authorInitials, avatarUrl, sourceUrl, sourcePlatform } = Astro.props as Props;
const tooltipContent = sourcePlatform ? `${authorName} (${sourcePlatform})` : authorName;
---

<Tooltip>
  <TooltipTrigger>
    <Link href={sourceUrl}>
      <Avatar class="hover:border-accent">
        {avatarUrl && <AvatarImage src={avatarUrl} alt={authorName} />}
        <AvatarFallback>{authorInitials}</AvatarFallback>
      </Avatar>
    </Link>
  </TooltipTrigger>
  <TooltipContent side="bottom">{tooltipContent}</TooltipContent>
</Tooltip>
