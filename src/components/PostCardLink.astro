---
import CalendarIcon from '@tabler/icons/outline/calendar-event.svg';
import type { HTMLAttributes } from 'astro/types';
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { Card, CardDescription, CardFooter, CardHeader, CardTitle } from './starwind/card';

type Props = CollectionEntry<'posts'>['data'] & HTMLAttributes<'a'>;

const { href, title, description, heroImage, publishDate } = Astro.props;
---

<a href={href} class="block h-full" aria-label={`Read blog post ${title}`}>
  <Card
    class="group flex h-full flex-col justify-between p-2 transition-shadow hover:bg-accent/80 hover:shadow-xl md:p-3"
  >
    <div class="overflow-hidden rounded-xl">
      <Picture
        src={heroImage.src}
        alt={heroImage.alt}
        width={640}
        height={330}
        formats={['avif', 'webp']}
        quality={75}
        class="transition-transform duration-300 ease-out group-hover:scale-105"
      />
    </div>
    <CardHeader class="my-4 grow p-0">
      <CardTitle class="font-heading">{title}</CardTitle>
      <CardDescription class="line-clamp-3">{description}</CardDescription>
    </CardHeader>
    <CardFooter class="p-0">
      <CalendarIcon width={20} height={20} class="mr-2 inline-block" stroke-width={1} />
      <FormattedDate date={publishDate} class="text-sm font-semibold" />
    </CardFooter>
  </Card>
</a>
