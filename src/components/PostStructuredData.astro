---
import { POSTS_PATH } from '@/constants';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  publishDate: Date;
  updatedDate?: string;
}

const { title, description, image, publishDate, updatedDate } = Astro.props;
const imageUrl = new URL(image.src, Astro.site);

function createUrlWithoutTrailingSlash(urlString: string | URL): URL {
  const url = new URL(urlString);
  url.pathname = url.pathname.replace(/\/$/, '');
  return url;
}
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    image: [imageUrl],
    url: Astro.url,
    datePublished: publishDate.toISOString(),
    dateModified: updatedDate ? new Date(updatedDate).toISOString() : publishDate.toISOString(),
    author: [
      {
        '@type': 'Person',
        name: 'Fraser McLean',
        url: Astro.site!.origin
      }
    ]
  })}
/>

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.origin },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Posts',
        item: new URL(`${POSTS_PATH}`, Astro.site)
      },
      { '@type': 'ListItem', position: 3, name: title, item: new URL(Astro.url.pathname, Astro.site) }
    ]
  })}
/>
