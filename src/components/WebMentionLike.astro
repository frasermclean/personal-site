---
import { Avatar, AvatarFallback, AvatarImage } from '@/components/starwind/avatar';
import { Tooltip, TooltipContent, TooltipTrigger } from '@/components/starwind/tooltip';
import { convertNameToInitials } from '@/lib/avatar-naming';
import type { WebMentionEntry } from '@/lib/webmention-types';
import Link from './links/Link.astro';

interface Props {
  entry: WebMentionEntry;
}

const { entry } = Astro.props as Props;
---

<Tooltip>
  <TooltipTrigger>
    <Link href={entry.author.url}>
      <Avatar class="hover:border-accent">
        <AvatarImage src={entry.author.photo} alt={entry.author.name} />
        <AvatarFallback>{convertNameToInitials(entry.author.name)}</AvatarFallback>
      </Avatar>
    </Link>
  </TooltipTrigger>
  <TooltipContent side="bottom">{entry.author.name}</TooltipContent>
</Tooltip>
