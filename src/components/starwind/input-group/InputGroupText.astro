---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'span'>;

const { class: className, ...rest } = Astro.props;
---

<span
  class:list={[
    "flex items-center gap-2 text-sm text-muted-foreground [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4.5",
    className
  ]}
  {...rest}
>
  <slot />
</span>
