---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  caption: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'eager' | 'lazy';
}

const { image, caption, class: className, width, height, loading } = Astro.props;
---

<figure class={className}>
  <Image src={image} alt={caption} {width} {height} class="rounded" {loading} />
  <figcaption class="mt-2 text-center text-sm text-neutral-500">{caption}</figcaption>
</figure>
