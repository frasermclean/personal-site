---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  imagePath: string;
  caption: string;
  class?: string;
  width?: number;
  height?: number;
}

const { imagePath, caption, class: className, width, height } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}');

if (!images[imagePath]) {
  throw new Error(`"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif}"`);
}

const image = await images[imagePath]();
---

<figure class={className}>
  <Image src={image.default} alt={caption} width={width} height={height} class="mx-auto" />
  <figcaption class="mt-2 text-center text-sm text-neutral-500">{caption}</figcaption>
</figure>
