---
import ButtonLink from '@/components/links/ButtonLink.astro';
import Link from '@/components/links/Link.astro';
import { CONTACT_PATH } from '@/constants';
import MailIcon from '@tabler/icons/outline/mail.svg';
import RssIcon from '@tabler/icons/outline/rss.svg';
import SitemapIcon from '@tabler/icons/outline/sitemap.svg';
import FediringLinks from './FediringLinks.astro';
import IndieWebRingLinks from './IndieWebRingLinks.astro';

const currentYear = new Date().getFullYear();

const links = [
  {
    href: '/sitemap-index.xml',
    label: 'Sitemap',
    Icon: SitemapIcon
  },
  {
    href: '/rss.xml',
    label: 'RSS Feed',
    Icon: RssIcon
  }
];
---

<footer class="mx-auto flex w-full flex-col items-center bg-neutral-200 px-2 py-4 md:px-3 md:py-8 dark:bg-neutral-950">
  <h2 class="font-heading text-2xl text-accent md:text-3xl">Want to get in touch?</h2>
  <ButtonLink href={CONTACT_PATH} variant="outline" class="mt-4 mb-6">
    <MailIcon class="mr-2" width={24} height={24} stroke-width={1.25} />
    Contact Me
  </ButtonLink>
  <p class="mb-2 text-center text-sm text-muted-foreground">&copy; {currentYear} Fraser McLean. All rights reserved.</p>
  <nav class="flex flex-col items-center gap-1 text-sm text-neutral-500 sm:flex-row sm:gap-4">
    <ul class="flex gap-4">
      {
        links.map(({ href, label, Icon }) => (
          <li>
            <Link href={href} class="text-sm text-neutral-500 hover:text-accent/90 hover:underline">
              <Icon class="mr-1 inline-block" width={16} height={16} stroke-width={1.5} />
              {label}
            </Link>
          </li>
        ))
      }
    </ul>

    <div class="flex gap-2 sm:gap-3">
      <FediringLinks />
      <IndieWebRingLinks />
    </div>
  </nav>
</footer>
