---
import MobileMenu from './MobileMenu.astro';
import NavigationLinks from './NavigationLinks.astro';
import SiteLogo from './SiteLogo.astro';
import SocialLinks from './SocialLinks.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header
  class="sticky top-0 z-50 w-full bg-neutral-600/90 text-neutral-50 shadow-md backdrop-blur-md md:shadow-lg dark:bg-neutral-800/90 dark:text-neutral-100"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 p-2 md:p-3">
    <SiteLogo />
    <NavigationLinks class="hidden md:flex" />
    <div class="grow"></div>
    <SocialLinks class="hidden items-center gap-2 md:flex" />
    <ThemeToggle />
    <MobileMenu />
  </div>
</header>
