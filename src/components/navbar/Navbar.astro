---
import NavigationLinks from './NavigationLinks.astro';
import SiteLogo from './SiteLogo.astro';
import SocialLinks from './SocialLinks.astro';
import UserMenu from './UserMenu.astro';
---

<header class="sticky top-0 z-50 w-full bg-navbar text-navbar-foreground shadow-md backdrop-blur-md md:shadow-lg">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 p-2 md:p-3 2xl:px-0">
    <SiteLogo />
    <NavigationLinks class="hidden md:flex" />
    <div class="grow"></div>
    <SocialLinks class="flex items-center gap-2" />
    <UserMenu />
  </div>
</header>
