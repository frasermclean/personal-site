---
import { Button } from '@/components/starwind/button';
import {
  Dropdown,
  DropdownContent,
  DropdownItem,
  DropdownSeparator,
  DropdownTrigger
} from '@/components/starwind/dropdown';
import MenuIcon from '@tabler/icons/outline/menu-2.svg';
import MoonIcon from '@tabler/icons/outline/moon.svg';
import SunIcon from '@tabler/icons/outline/sun.svg';
import { links } from './NavigationLinks.astro';
import BookmarkIcon from '@tabler/icons/outline/bookmark.svg';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/starwind/avatar';
import { BOOKMARKS_PATH } from '@/constants';
import SignOut from '@/components/navbar/SignOut.astro';
import SignIn from '@/components/navbar/SignIn.astro';

const user = Astro.locals.user;
const displayName = user?.name ?? user?.githubUsername ?? '';
---

<Dropdown>
  <DropdownTrigger asChild>
    <Button size="icon" class="rounded-full" aria-label="User menu">
      {
        user ? (
          <Avatar size="sm">
            <AvatarImage src={user.avatarUrl} alt={displayName} />
            <AvatarFallback>{displayName?.[0]}</AvatarFallback>
          </Avatar>
        ) : (
          <MenuIcon />
        )
      }
    </Button>
  </DropdownTrigger>
  <DropdownContent align="end">
    <nav class="sm:hidden">
      <ul>
        {
          links.map(({ href, text, Icon }) => (
            <li>
              <DropdownItem as="a" href={href}>
                {Icon && <Icon width={28} stroke-width={1.25} />}
                {text}
              </DropdownItem>
            </li>
          ))
        }
      </ul>

      <DropdownSeparator />
    </nav>

    <DropdownItem as="a" href={BOOKMARKS_PATH}>
      <BookmarkIcon width={28} stroke-width={1.25} />
      Bookmarks
    </DropdownItem>
    <DropdownSeparator />

    <DropdownItem as="button" id="theme-button" class="w-full">
      <MoonIcon class="hidden dark:block" />
      <SunIcon class="block dark:hidden" />
      Theme
    </DropdownItem>

    {user ? <SignOut /> : <SignIn />}
  </DropdownContent>
</Dropdown>

{user && <div id="user-identifier" class="hidden" data-email={user.email} />}

<script>
  import { getTheme, setTheme } from '@/lib/local-storage';

  updateDom(getPreferrredTheme()); // set initial theme based on user preference

  // add click event listener to the button
  const button = document.getElementById('theme-button');
  button?.addEventListener('click', () => {
    const theme = getPreferrredTheme() === 'dark' ? 'light' : 'dark'; // toggle theme
    setTheme(theme);
    updateDom(theme);
    umami.track('theme-change', { theme }); // track theme change event
  });

  function getPreferrredTheme(): 'light' | 'dark' {
    // check localStorage first
    const storedTheme = getTheme();
    if (storedTheme) {
      return storedTheme;
    }

    // read the user's system preference (and default to light if no match)
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function updateDom(theme: 'light' | 'dark') {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }

  // identify the user by their email for analytics purposes (if available)
  const userIdentifier = document.getElementById('user-identifier');
  if (userIdentifier) {
    const email = userIdentifier.dataset.email;
    if (email) {
      umami.identify(email);
    }
  }
</script>
