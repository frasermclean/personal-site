---
import logo from '@/assets/site-logo.png';
import Link from '@/components/links/Link.astro';
import { HOME_PATH } from '@/constants';
import { Image } from 'astro:assets';

interface Props {
  size?: number;
}

const { size = 44 } = Astro.props;
---

<Link href={HOME_PATH} class="h-card rounded-md border-2 border-neutral-500 hover:border-accent/80" aria-label="Home">
  <Image src={logo} alt="Site Logo" class="u-logo" width={size} height={size} />
</Link>
