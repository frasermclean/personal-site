---
import { actions } from 'astro:actions';
import BubblesVoteCount from './BubblesVoteCount.astro';
import WebMentionLikes from './WebMentionLikes.astro';
import Link from './links/Link.astro';
import WebMentionLike from './WebMentionLike.astro';

interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;
const { data: entries = [], error } = await Astro.callAction(actions.getWebMentions, { slug });

const likes = !error ? entries.filter((entry) => entry['wm-property'] === 'like-of') : [];
---

<section class="my-8">
  <h2 id="reactions" class="mb-4 font-heading text-2xl font-bold text-primary md:text-4xl">Reactions</h2>

  
  {entries.length === 0 && <p>No reactions yet. Be the first to react!</p>}
  {
    likes.length > 0 && (
    <h3 class="font-heading text-lg font-semibold text-secondary">
      Liked by {likes.length}
      {likes.length === 1 ? 'person' : 'people'}
    </h3>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        likes.map((entry) => (
          <li>
            <WebMentionLike {entry} />
          </li>
        ))
      }
    </ul>
    )
  }
  <p class="mt-3 text-sm text-muted-foreground">
    Powered by <Link href="https://webmention.io/" class="hover:text-accent/90 hover:underline">Webmention.io</Link>
  </p>

  <BubblesVoteCount />
</section>
