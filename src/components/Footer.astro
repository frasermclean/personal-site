---
import ButtonLink from '@/components/links/ButtonLink.astro';
import Link from '@/components/links/Link.astro';
import { CONTACT_PATH } from '@/constants';
import ChevronLeftIcon from '@tabler/icons/outline/chevron-left.svg';
import ChevronRightIcon from '@tabler/icons/outline/chevron-right.svg';
import MailIcon from '@tabler/icons/outline/mail.svg';
import RssIcon from '@tabler/icons/outline/rss.svg';
import SitemapIcon from '@tabler/icons/outline/sitemap.svg';

const currentYear = new Date().getFullYear();
const host = Astro.site?.hostname;

const links = [
  {
    href: '/sitemap-index.xml',
    label: 'Sitemap',
    Icon: SitemapIcon
  },
  {
    href: '/rss.xml',
    label: 'RSS Feed',
    Icon: RssIcon
  }
];
---

<footer class="mx-auto flex flex-col items-center px-2 py-8 md:px-3">
  <h2 class="font-heading text-2xl text-accent md:text-3xl">Want to get in touch?</h2>
  <ButtonLink href={CONTACT_PATH} variant="outline" class="mt-4 mb-6">
    <MailIcon class="mr-2" width={24} height={24} stroke-width={1.25} />
    Contact Me
  </ButtonLink>
  <p class="mb-2 text-center text-sm text-muted-foreground">&copy; {currentYear} Fraser McLean. All rights reserved.</p>
  <nav>
    <ul class="flex gap-4 text-sm text-neutral-500">
      {
        links.map(({ href, label, Icon }) => (
          <li>
            <Link href={href} class="text-sm text-neutral-500 hover:text-accent/90 hover:underline">
              <Icon class="mr-1 inline-block" width={16} height={16} stroke-width={1.5} />
              {label}
            </Link>
          </li>
        ))
      }
      <li>
        <Link
          href={`https://fediring.net/previous?host=${host}`}
          class="hover:text-accent/90"
          aria-label="Previous site in Fediring"
        >
          <ChevronLeftIcon class="inline-block" width={16} height={16} stroke-width={1.5} />
        </Link>
        <Link href="https://fediring.net/" class="hover:text-accent/90 hover:underline">Fediring</Link>
        <Link
          href={`https://fediring.net/next?host=${host}`}
          class="hover:text-accent/90"
          aria-label="Next site in Fediring"
        >
          <ChevronRightIcon class="inline-block" width={16} height={16} stroke-width={1.5} />
        </Link>
      </li>

      <li>
        <Link
          href="https://xn--sr8hvo.ws/previous"
          class="hover:text-accent/90"
          aria-label="Previous site in IndieWeb Webring"
        >
          <ChevronLeftIcon class="inline-block" width={16} height={16} stroke-width={1.5} />
        </Link>
        <Link href="https://xn--sr8hvo.ws/" class="hover:text-accent/90 hover:underline">IndieWeb</Link>
        <Link href="https://xn--sr8hvo.ws/next" class="hover:text-accent/90" aria-label="Next site in IndieWeb Webring">
          <ChevronRightIcon class="inline-block" width={16} height={16} stroke-width={1.5} />
        </Link>
      </li>
    </ul>
  </nav>
</footer>
