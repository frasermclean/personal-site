---
import defaultOgImage from '@/assets/default-og-image.png';
import Footer from '@/components/Footer.astro';
import Navbar from '@/components/navbar/Navbar.astro';
import Separator from '@/components/starwind/separator';
import { SITE_TITLE } from '@/constants.ts';
import '@/styles/starwind.css';
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import geistFont from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2';
import '@fontsource-variable/sora';
import soraFont from '@fontsource-variable/sora/files/sora-latin-wght-normal.woff2';
import type { ImageMetadata } from 'astro';
import { TRACKING_SCRIPT_SRC, TRACKING_WEBSITE_ID, WORKERS_CI_COMMIT_SHA } from 'astro:env/client';

export interface Props {
  title: string;
  description: string;
  isArticle?: boolean;
  heroImage?: {
    src: ImageMetadata;
    alt?: string;
  };
}

const { title, description, isArticle = false, heroImage } = Astro.props;
const canonicalUrl = Astro.url.pathname === '/' ? Astro.site!.origin : new URL(Astro.url.pathname, Astro.site).href;
const image = heroImage?.src || defaultOgImage;
const imageUrl = new URL(image.src, Astro.site);

const fullTitle = title.length < 30 ? `${title} | ${SITE_TITLE}` : title;
---

<!doctype html>
<html lang="en">
  <head>
    <title>{fullTitle}</title>
    <meta charset="utf-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Font preloads -->
    <link rel="preload" as="font" type="font/woff2" href={soraFont} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={geistFont} crossorigin />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content={image.width.toString()} />
    <meta property="og:image:height" content={image.height.toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@frasermclean81" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={imageUrl} />

    <meta name="fediverse:creator" content="@frasermclean@mastodon.social" />

    <slot name="head" />

    <!-- Analytics -->
    <script
      is:inline
      defer
      src={TRACKING_SCRIPT_SRC}
      data-website-id={TRACKING_WEBSITE_ID}
      data-domains={Astro.site?.hostname || null}
      data-tag={WORKERS_CI_COMMIT_SHA || null}></script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Navbar />
    <main class="mx-auto max-w-7xl flex-1 px-2 md:px-3">
      <slot />
    </main>
    <Separator />
    <Footer />
  </body>
</html>
