---
import HeroSection from '@/components/HeroSection.astro';
import { Button } from '@/components/starwind/button';
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/starwind/card';
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle } from '@/components/starwind/dialog';
import { InputGroup, InputGroupAddon, InputGroupInput } from '@/components/starwind/input-group';
import { Label } from '@/components/starwind/label';
import { Textarea } from '@/components/starwind/textarea';
import BaseLayout from '@/layouts/BaseLayout.astro';
import MailIcon from '@tabler/icons/outline/mail.svg';
import UserIcon from '@tabler/icons/outline/user.svg';
import SendIcon from '@tabler/icons/outline/send.svg';
import { TURNSTILE_SITE_KEY } from 'astro:env/client';

const title = 'Contact Me';
const subtitle = "If you have any questions or inquiries, I'd love to hear from you!";
const description =
  'Make use of the contact form to get in touch with me with any questions or inquiries. Just fill in your details, and I will get back to you as soon as possible.';
---

<link rel="preconnect" href="https://challenges.cloudflare.com" slot="head" />
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer slot="head"></script>

<BaseLayout {title} {description}>
  <HeroSection {title} {subtitle} />

  <Card class="mx-auto max-w-md" as="form">
    <CardHeader>
      <CardTitle>Get in Touch</CardTitle>
      <CardDescription>Fill out the form below to contact me.</CardDescription>
    </CardHeader>

    <CardContent class="space-y-4">
      <div class="flex flex-col gap-1">
        <Label for="name">Full Name</Label>
        <InputGroup>
          <InputGroupAddon align="inline-start">
            <UserIcon />
          </InputGroupAddon>
          <InputGroupInput id="name" type="text" placeholder="Bob Jones" autocomplete="name" required />
        </InputGroup>
      </div>

      <div class="flex flex-col gap-1">
        <Label for="email">Email Address</Label>
        <InputGroup>
          <InputGroupInput id="email" type="email" placeholder="bob.jones@example.com" autocomplete="email" required />
          <InputGroupAddon align="inline-start">
            <MailIcon />
          </InputGroupAddon>
        </InputGroup>
      </div>

      <div class="flex flex-col gap-1">
        <Label for="message">Message</Label>
        <Textarea id="message" placeholder="Hi there" rows="6" required />
      </div>

      <div class="cf-turnstile w-full" data-sitekey={TURNSTILE_SITE_KEY} data-size="flexible"></div>
    </CardContent>
    <CardFooter class="flex-col gap-4">
      <Button class="w-full" variant="primary" type="submit" disabled>
        <SendIcon class="mr-2" />
        Send Message
      </Button>
    </CardFooter>
  </Card>

  <Dialog id="result-dialog">
    <DialogContent>
      <DialogHeader>
        <DialogTitle>Title</DialogTitle>
        <DialogDescription>Description</DialogDescription>
      </DialogHeader>
      <p id="dialog-message" class="pt-4">Message</p>
    </DialogContent>
  </Dialog>

  <script>
    import { actions } from 'astro:actions';

    const form = document.querySelector<HTMLFormElement>('form');
    const nameInput = document?.querySelector<HTMLInputElement>('#name');
    const emailInput = document?.querySelector<HTMLInputElement>('#email');
    const messageInput = document?.querySelector<HTMLTextAreaElement>('#message');

    nameInput?.addEventListener('input', validateForm);
    emailInput?.addEventListener('input', validateForm);
    messageInput?.addEventListener('input', validateForm);

    nameInput?.addEventListener('blur', () => setInvalidState(nameInput));
    emailInput?.addEventListener('blur', () => setInvalidState(emailInput));
    messageInput?.addEventListener('blur', () => setInvalidState(messageInput));

    function setInvalidState(input: HTMLInputElement | HTMLTextAreaElement) {
      input.setAttribute('aria-invalid', input.checkValidity() ? 'false' : 'true');
    }

    function validateForm() {
      const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

      if (!nameInput || !emailInput || !messageInput || !submitButton) {
        console.error('Form elements not found');
        return;
      }
      const isValid = nameInput.checkValidity() && emailInput.checkValidity() && messageInput.checkValidity();
      submitButton.disabled = !isValid;

      // Update aria-invalid for fields that have already been touched (aria-invalid already set)
      for (const input of [nameInput, emailInput, messageInput]) {
        if (input.hasAttribute('aria-invalid')) {
          setInvalidState(input);
        }
      }
    }

    function getFormValues() {
      const tokenInput = form?.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
      return {
        name: nameInput?.value.trim(),
        email: emailInput?.value.trim(),
        message: messageInput?.value.trim(),
        token: tokenInput?.value
      };
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const { name, email, message, token } = getFormValues();

      if (!name || !email || !message || !token) {
        showDialog('Error', 'Form is incomplete', 'Please fill out all fields before submitting the form.');
        return;
      }

      const { error } = await actions.processContactForm({ name, email, message, token });

      if (error) {
        console.error('Error submitting form:', error);
        showDialog('Error', 'Submission failed', 'There was an error sending your message. Please try again later.');
        return;
      }

      form.reset();
      showDialog(
        'Success',
        'Message sent successfully',
        `Thank you for reaching out, ${name}. I'll get back to you as soon as possible!`
      );
    });

    function showDialog(title: string, description: string, message: string) {
      const dialog = document.querySelector<HTMLDialogElement>('#result-dialog dialog');
      const backdrop = document.querySelector<HTMLElement>('#result-dialog .starwind-dialog-backdrop');
      const titleElement = document.querySelector<HTMLElement>('#result-dialog [data-slot="dialog-title"]');
      const descriptionElement = document.querySelector<HTMLElement>('#result-dialog [data-slot="dialog-description"]');
      const messageElement = document.querySelector<HTMLElement>('#dialog-message');

      if (!dialog || !backdrop || !titleElement || !descriptionElement || !messageElement) {
        console.error('Dialog elements not found');
        return;
      }

      // update dialog content
      titleElement.textContent = title;
      descriptionElement.textContent = description;
      messageElement.textContent = message;

      // show the dialog and backdrop
      document.body.classList.add('overflow-hidden');
      dialog.showModal();
      dialog.dataset.state = 'open';
      backdrop.classList.remove('hidden');
      backdrop.dataset.state = 'open';
    }
  </script>
</BaseLayout>
