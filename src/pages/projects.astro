---
import HeroSection from '@/components/HeroSection.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';

const title = 'Project Portfolio';
const description = 'A selection of public projects that I have worked on over the years.';
const collection = await getCollection('projects');

const projectImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/projects/*.{jpeg,jpg,png,gif}');

async function getProjectImage(imageFile?: string) {
  if (!imageFile) return undefined;

  const imagePath = `/src/assets/projects/${imageFile}`;

  if (!projectImages[imagePath]) return undefined;

  const image = await projectImages[imagePath]();
  return image.default;
}
---

<BaseLayout {title} {description}>
  <HeroSection {title} subtitle={description} />
  <ul class="mx-auto flex max-w-4xl flex-col gap-4">
    {
      await Promise.all(
        collection.map(async (project) => {
          const image = await getProjectImage(project.data.imageFile);
          return <ProjectCard id={project.id} {image} />;
        })
      )
    }
  </ul>
</BaseLayout>
