---
import HeroSection from '@/components/HeroSection.astro';
import SkillsSection from '@/components/SkillsSection.astro';
import { POSTS_PATH, PROJECTS_PATH } from '@/constants';
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Fraser McLean';
const description = 'Software engineer and technology enthusiast.';
---

<BaseLayout title={title} description={description}>
  <HeroSection
    title={title}
    subtitle={description}
    primaryCta={{ label: 'View Projects', href: PROJECTS_PATH }}
    secondaryCta={{ label: 'Read Blog', href: POSTS_PATH }}
  />
  <SkillsSection />
</BaseLayout>
