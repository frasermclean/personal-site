---
import HeroSection from '@/components/HeroSection.astro';
import SkillsSection from '@/components/SkillsSection.astro';
import { POSTS_PATH, PROJECTS_PATH } from '@/constants';
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Fraser McLean';
const subtitle = 'Software engineer and technology enthusiast.';
const description =
  'Personal website of Fraser McLean - software engineer and technology enthusiast. Showcasing projects, blog posts, and skills in software development.';
---

<BaseLayout title={title} description={description}>
  <HeroSection
    title={title}
    subtitle={subtitle}
    primaryCta={{ label: 'View Projects', href: PROJECTS_PATH }}
    secondaryCta={{ label: 'Read Blog', href: POSTS_PATH }}
  />
  <SkillsSection />
</BaseLayout>
