---
import { CATEGORIES_PATH } from '@/constants';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'node_modules/astro/dist/types/public/common';

export const getStaticPaths = (async () => {
  const allPosts = await getCollection('posts');

  // get all unique categories from posts
  const uniqueCategories = [...new Set(allPosts.map((post) => post.data.category).filter(Boolean))];

  // create routes for each category
  return uniqueCategories.map((category) => ({
    params: { category }
  }));
}) satisfies GetStaticPaths;

const { category } = Astro.params;

// Rewrite to the first page of the tag
return Astro.rewrite(`${CATEGORIES_PATH}/${category}/1`);
---
