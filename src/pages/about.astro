---
import headshotImage from '@/assets/fraser-headshot.jpg';
import HeroSection from '@/components/HeroSection.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Image from 'astro/components/Image.astro';

const title = 'About Me';
const description = 'A little bit about who I am and what I do.';
---

<BaseLayout {title} {description}>
  <HeroSection {title} subtitle={description} />
  <section class="mx-auto flex w-full max-w-2xl flex-col-reverse gap-8 md:flex-row">
    <div class="grow text-center md:text-right">
      <h2 class="mb-4 font-heading text-4xl font-bold text-secondary">Hi there!</h2>
      <p class="text-lg text-neutral-300">
        My name is Fraser McLean, and I am a software developer with a passion for creating intuitive and efficient
        applications. Welcome to my personal space on the web where I share my thoughts, projects, and experiences in
        the world.
      </p>
    </div>

    <Image
      src={headshotImage}
      width={256}
      height={256}
      alt="Fraser McLean Headshot"
      class="mx-auto rounded-full border-4"
    />
  </section>
</BaseLayout>
