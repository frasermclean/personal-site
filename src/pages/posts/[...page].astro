---
import FeaturedPost from '@/components/FeaturedPost.astro';
import PopularTags from '@/components/PopularTags.astro';
import { POSTS_PAGE_SIZE, POSTS_PATH } from '@/constants';
import PostListLayout from '@/layouts/PostListLayout.astro';
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const entries = (await getCollection('posts'))
    .filter((post) => !post.data.isFeatured)
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
  return paginate(entries, {
    pageSize: POSTS_PAGE_SIZE
  }).map((result) => ({
    ...result,
    params: { page: result.props.page.currentPage === 1 ? undefined : `page/${result.props.page.currentPage}` }
  }));
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const title = page.currentPage === 1 ? 'Blog Posts' : `Blog Posts - Page ${page.currentPage}`;
const description =
  'A collection of blog posts on various topics including web development, programming, and technology.';
---

<PostListLayout {title} {description} {page} paginationBasePath={`${POSTS_PATH}`}>
  {
    page.currentPage === 1 && (
      <div class="my-8 grid grid-cols-1 gap-4 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <FeaturedPost />
        </div>
        <div class="lg:col-span-1">
          <PopularTags />
        </div>
      </div>
    )
  }
</PostListLayout>
