---
import CategoryLink from '@/components/links/CategoryLink.astro';
import PostBreadcrumbs from '@/components/PostBreadcrumbs.astro';
import PostMetadata from '@/components/PostMetadata.astro';
import PostReactions from '@/components/PostReactions.astro';
import Prose from '@/components/Prose.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import Article from '@/components/structured-data/Article.astro';
import type { BreadcrumbItem } from '@/components/structured-data/BreadcrumbList.astro';
import BreadcrumbList from '@/components/structured-data/BreadcrumbList.astro';
import SyndicationList from '@/components/SyndicationList.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import TagList from '@/components/TagList.astro';
import { POSTS_PATH } from '@/constants';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getRelatedPosts } from '@/lib/related-posts';
import { Picture } from 'astro:assets';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;
if (!slug) {
  throw new Error('Slug parameter is required');
}

const entry = await getEntry('posts', slug);
if (!entry) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { title, description, heroImage, publishDate, category, tags, syndication, showReactions } = entry.data;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const { updatedDate, readingTime } = remarkPluginFrontmatter;
const relatedPosts = await getRelatedPosts(slug, category, tags);

const breadcrumbItems: BreadcrumbItem[] = [
  { title: 'Home', url: Astro.site!.origin },
  { title: 'Posts', url: new URL(`${POSTS_PATH}`, Astro.site) },
  { title }
];
---

<BaseLayout {title} {description} isArticle={true} {heroImage} mainClass="h-entry">
  <Article {title} {description} image={heroImage.src} {publishDate} {updatedDate} slot="head" />
  <BreadcrumbList items={breadcrumbItems} slot="head" />

  <Picture
    src={heroImage.src}
    alt={heroImage.alt}
    width={1280}
    height={660}
    formats={['avif', 'webp']}
    class="mt-4 mb-8 rounded-4xl shadow-xl md:my-12"
    quality={85}
  />

  <PostMetadata {title} {description} {publishDate} {updatedDate} {readingTime} class="my-8 md:my-12" />
  <PostBreadcrumbs {title} class="mb-8 hidden md:block" />

  <div class="flex w-full">
    <Prose class="e-content w-full max-w-none xl:max-w-prose">
      <Content />
    </Prose>
    <aside class="sticky top-24 hidden grow flex-col gap-6 self-start pl-4 xl:flex">
      <TableOfContents
        headings={headings}
        includeReactionsLink={showReactions}
        includeRelatedPostsLink={relatedPosts.length > 0}
      />
      {category && <CategoryLink category={category} />}
      {tags.length > 0 && <TagList tags={tags} />}
      {syndication && <SyndicationList {...syndication} />}
    </aside>
  </div>

  {showReactions && <PostReactions {slug} />}
  {relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} />}
</BaseLayout>
