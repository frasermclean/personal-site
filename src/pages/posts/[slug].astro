---
import PostViewLayout from '@/layouts/PostViewLayout.astro';
import { getEntry, render } from 'astro:content';

const slug = Astro.params.slug;
if (!slug) {
  throw new Error('Post slug is missing from route parameters.');
}

const entry = await getEntry('posts', slug);
if (!entry) {
  Astro.response.status = 404;
  throw new Error(`Post with slug "${slug}" not found.`);
}

const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const { updatedDate, readingTime } = remarkPluginFrontmatter;
const props = { ...entry.data, slug, headings, updatedDate, readingTime };
---

<PostViewLayout {...props}>
  <Content />
</PostViewLayout>
