---
import { POSTS_PAGE_SIZE, TAGS_PATH } from '@/constants';
import PostListLayout from '@/layouts/PostListLayout.astro';
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');

  // Get all unique tags
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  // Create paginated routes for each tag
  return uniqueTags.flatMap((tag) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

    return paginate(filteredPosts, {
      params: { tag },
      pageSize: POSTS_PAGE_SIZE
    }).map((result) => ({
      ...result,
      params: {
        tag,
        page: result.props.page.currentPage === 1 ? undefined : `page/${result.props.page.currentPage}`
      }
    }));
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { tag } = Astro.params;

const title = `Posts tagged with "${tag}"`;
const description =
  page.lastPage === 1
    ? `A collection of blog posts tagged with "${tag}".`
    : `Page ${page.currentPage} of ${page.lastPage} of blog posts tagged with "${tag}".`;
const listTitle = page.lastPage === 1 ? 'Matching Posts' : `Matching Posts - Page ${page.currentPage}`;
---

<PostListLayout {title} {description} {listTitle} {page} paginationBasePath={`${TAGS_PATH}/${tag}`} />
