{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "personal-site",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "workers_dev": true,
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "none",
    "html_handling": "drop-trailing-slash"
  },
  "vars": {
    "ANALYTICS_DOMAIN": "frasermclean.com",
    "ANALYTICS_PERFORMANCE": "true",
    "ANALYTICS_SCRIPT_SRC": "https://analytics.frasermclean.com/script.js",
    "ANALYTICS_WEBSITE_ID": "a366d3c3-624c-4f34-9071-7d155090ac6a",
    "TURNSTILE_SITE_KEY": "0x4AAAAAAAhX2PdPqj0Cojk1",
    "GITHUB_CLIENT_ID": "f93d1abe0a16cca1040d"
  },
  "routes": [
    {
      "pattern": "frasermclean.com",
      "custom_domain": true
    },
    {
      "pattern": "www.frasermclean.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "a839b04fba2a4abc81addab7cc996649"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "personal-site",
      "database_id": "66c9ef15-467e-4c24-aa29-23fb1ff921f1"
    }
  ]
}
