{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "main": "dist/_worker.js/index.js",
  "name": "frasermclean-site",
  "compatibility_date": "2025-11-09",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "workers_dev": true,
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "drop-trailing-slash"
  },
  "vars": {
    "COMMENTS_HOST": "https://comments.frasermclean.com",
    "TRACKING_WEBSITE_ID": "a366d3c3-624c-4f34-9071-7d155090ac6a",
    "TURNSTILE_SITE_KEY": "0x4AAAAAAAhX2PdPqj0Cojk1"
  },
  "routes": [
    {
      "pattern": "frasermclean.com",
      "custom_domain": true
    },
    {
      "pattern": "www.frasermclean.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "a839b04fba2a4abc81addab7cc996649"
    }
  ]
}
